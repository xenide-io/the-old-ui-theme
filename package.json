{
  "name": "@xenide-io/the-old-ui",
  "version": "0.2.1",
  "description": "Props-driven React components and theme tokens inspired by classic interface design — optimized for Next.js apps and internal tools.",
  "author": "Xenide",
  "license": "MIT",
  "homepage": "https://github.com/xenide-io/the-old-ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xenide-io/the-old-ui.git"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "tailwindcss",
    "design-system",
    "theming"
  ],
  "packageManager": "bun@1.3.5",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    },
    "./styles.css": "./src/app/globals.css",
    "./themes.css": "./src/styles/themes.css",
    "./tailwind-preset": {
      "types": "./dist/tailwind-preset.d.ts",
      "import": "./dist/tailwind-preset.mjs",
      "require": "./dist/tailwind-preset.js",
      "default": "./dist/tailwind-preset.mjs"
    }
  },
  "files": [
    "dist",
    "src/app/globals.css",
    "src/styles",
    "tailwind-preset.ts"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:lib": "tsup src/index.ts tailwind-preset.ts --format cjs,esm --dts --external react,react-dom,next --clean --tsconfig ./tsconfig.lib.json",
    "start": "next start",
    "lint": "next lint",
    "test": "tsc --noEmit",
    "clean": "rm -rf .next out *.tsbuildinfo dist",
    "icons:check": "node scripts/sync-posthog-icons.mjs",
    "prepublishOnly": "bun run build:lib",
    "release": "bun run test && npm publish"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "next": ">=14.0.0",
    "tailwindcss": "^3.4.0",
    "chart.js": "^4.5.1",
    "react-chartjs-2": "^5.3.1",
    "d3-scale": "^4.0.2"
  },
  "peerDependenciesMeta": {
    "chart.js": {
      "optional": true
    },
    "react-chartjs-2": {
      "optional": true
    },
    "d3-scale": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "chart.js": "^4.5.1",
    "d3-scale": "^4.0.2",
    "next": "^14.0.0",
    "postcss": "^8.4.39",
    "react": "^18.0.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.0.0",
    "tailwindcss": "^3.4.4",
    "tsup": "^8.5.1",
    "typescript": "^5.5.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
